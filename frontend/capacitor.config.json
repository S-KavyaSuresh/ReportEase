{
  "appId":      "com.reportease.app",
  "appName":    "ReportEase",
  "webDir":     "build",
  "bundledWebRuntime": false,
  "server": {
    "androidScheme": "https",
    "cleartext":     false
  },
  "android": {
    "buildOptions": {
      "keystorePath":  "../release.keystore",
      "keystoreAlias": "reportease"
    }
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 1500,
      "backgroundColor":    "#07080f",
      "showSpinner":        false
    },
    "StatusBar": {
      "style":           "DARK",
      "backgroundColor": "#07080f"
    }
  }
}
